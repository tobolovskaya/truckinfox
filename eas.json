{
  "cli": {
    "version": ">= 13.2.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "your-supabase-url",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "your-supabase-anon-key",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "your-google-maps-api-key",
        "EXPO_PUBLIC_GOOGLE_PLACES_API_KEY": "your-google-places-api-key",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "your-google-ios-client-id",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "your-google-android-client-id",
        "GOOGLE_MAPS_IOS_KEY": "your-google-maps-ios-key",
        "GOOGLE_MAPS_ANDROID_KEY": "your-google-maps-android-key"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false,
        "autoIncrement": true
      },
      "android": {
        "buildType": "apk",
        "autoIncrement": true
      },
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "your-supabase-url",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "your-supabase-anon-key",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "your-google-maps-api-key",
        "EXPO_PUBLIC_GOOGLE_PLACES_API_KEY": "your-google-places-api-key",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "your-google-ios-client-id",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "your-google-android-client-id",
        "GOOGLE_MAPS_IOS_KEY": "your-google-maps-ios-key",
        "GOOGLE_MAPS_ANDROID_KEY": "your-google-maps-android-key"
      }
    },
    "production": {
      "channel": "production",
      "ios": {
        "simulator": false,
        "autoIncrement": true
      },
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": true
      },
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "your-supabase-url",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "your-supabase-anon-key",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "your-google-maps-api-key",
        "EXPO_PUBLIC_GOOGLE_PLACES_API_KEY": "your-google-places-api-key",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "your-google-ios-client-id",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "your-google-android-client-id",
        "GOOGLE_MAPS_IOS_KEY": "your-google-maps-ios-key",
        "GOOGLE_MAPS_ANDROID_KEY": "your-google-maps-android-key"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "your-apple-id@example.com",
        "ascAppId": "your-app-store-connect-app-id",
        "appleTeamId": "YOUR_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
