{
  "expo": {
    "name": "TruckinFox",
    "slug": "truckinfox",
    "version": "1.0.0",
    "scheme": "truckinfox",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "primaryColor": "#FF7043",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF7043"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.truckinfox.app",
      "config": {
        "googleMapsApiKey": "$(GOOGLE_MAPS_IOS_KEY)"
      },
      "entitlements": {
        "com.apple.developer.applesignin": ["Default"]
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TruckinFox needs access to your location to show delivery routes and track cargo.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "TruckinFox needs access to your location to provide real-time tracking during deliveries.",
        "NSCameraUsageDescription": "TruckinFox needs access to your camera to take photos of cargo and delivery confirmation.",
        "NSPhotoLibraryUsageDescription": "TruckinFox needs access to your photo library to upload cargo images.",
        "NSPhotoLibraryAddUsageDescription": "TruckinFox needs permission to save cargo photos to your library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.truckinfox.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF7043"
      },
      "config": {
        "googleMaps": {
          "apiKey": "$(GOOGLE_MAPS_ANDROID_KEY)"
        }
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#FF7043"
        }
      ],
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow TruckinFox to use your location for real-time cargo tracking."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow TruckinFox to access your camera for cargo photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF7043"
        }
      ],
      "expo-localization",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "TruckinFox needs access to your photo library to upload cargo images.",
          "cameraPermission": "TruckinFox needs access to your camera to take photos of cargo."
        }
      ]
    ],
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-eas-project-id-replace-before-deployment"
      },
      "privacyPolicyUrl": "https://truckinfox.no/privacy"
    }
  }
}
