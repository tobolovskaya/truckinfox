# Firebase Configuration
# Get these from Firebase Console > Project Settings > General
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Brønnøysundregistrene API (Carrier Verification)
EXPO_PUBLIC_BRREG_API_URL=https://data.brreg.no/enhetsregisteret/api

# Redis Configuration (Optional)
EXPO_PUBLIC_REDIS_REST_URL=
EXPO_PUBLIC_REDIS_REST_TOKEN=
EXPO_PUBLIC_REDIS_URL=
EXPO_PUBLIC_REDIS_HOST=
EXPO_PUBLIC_REDIS_PORT=

# Google Maps/Places API Keys
# ⚠️ SECURITY: These keys are exposed in the app bundle (development only)
# For production deployment:
# 1. Remove EXPO_PUBLIC_GOOGLE_PLACES_API_KEY from this file
# 2. Move key to Firebase Cloud Functions environment variables
# 3. Update client code to call Cloud Function proxy instead
# See: GOOGLE_PLACES_API_SECURITY.md for detailed migration guide
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Google OAuth (Firebase Authentication)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Algolia Search (Cargo Requests)
EXPO_PUBLIC_ALGOLIA_APP_ID=your_algolia_app_id
EXPO_PUBLIC_ALGOLIA_SEARCH_KEY=your_algolia_search_key
EXPO_PUBLIC_ALGOLIA_CARGO_REQUESTS_INDEX=cargo_requests

# App Environment
EXPO_PUBLIC_NODE_ENV=development

# Production Setup (Firebase Cloud Functions)
# Once deployed, remove EXPO_PUBLIC_GOOGLE_PLACES_API_KEY above
# and set the private key in Firebase Console > Functions > Runtime settings:
# GOOGLE_PLACES_API_KEY=your_key_here
