# Supabase Configuration
# Self-hosted example URL: http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Brønnøysundregistrene API (Carrier Verification)
EXPO_PUBLIC_BRREG_API_URL=https://data.brreg.no/enhetsregisteret/api

# Vipps Payment Configuration
EXPO_PUBLIC_VIPPS_FUNCTION_NAME=vipps-verify-carrier

# Redis Configuration (Optional)
EXPO_PUBLIC_REDIS_REST_URL=
EXPO_PUBLIC_REDIS_REST_TOKEN=
EXPO_PUBLIC_REDIS_URL=
EXPO_PUBLIC_REDIS_HOST=
EXPO_PUBLIC_REDIS_PORT=

# Google Maps/Places API Keys
# Create at console.cloud.google.com — enable: Maps SDK for iOS, Maps SDK for Android, Places API
# For EAS builds these are injected via EAS Secrets (not committed to git):
#   eas secret:create --scope project --name GOOGLE_MAPS_IOS_KEY --value "AIzaSy..."
#   eas secret:create --scope project --name GOOGLE_MAPS_ANDROID_KEY --value "AIzaSy..."
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
GOOGLE_MAPS_IOS_KEY=your_google_maps_ios_key_here
GOOGLE_MAPS_ANDROID_KEY=your_google_maps_android_key_here


# App Environment
EXPO_PUBLIC_NODE_ENV=development

# Production Setup (Backend)
# Once deployed, remove EXPO_PUBLIC_GOOGLE_PLACES_API_KEY above
# and set the private key in your backend runtime settings:
# GOOGLE_PLACES_API_KEY=your_key_here
